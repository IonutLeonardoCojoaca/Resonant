<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring (oval = perfect circle) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#44FF3333"/>
        </shape>
    </item>
    <!-- Inner red fill -->
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="#E21616"/>
            <stroke
                android:width="1.5dp"
                android:color="#FF5555"/>
        </shape>
    </item>
</layer-list>
