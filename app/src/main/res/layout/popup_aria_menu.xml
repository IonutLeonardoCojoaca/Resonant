<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_aria_popup_menu"
    android:padding="6dp">

    <!-- Opción 1: Info -->
    <LinearLayout
        android:id="@+id/menuItemInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="@drawable/bg_aria_popup_item"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_aria_popup_icon_neutral"
            android:layout_marginEnd="10dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_info"
                app:tint="#AAAAAA"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Qué puede hacer Aria?"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/unageo_medium"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver capacidades"
                android:textColor="#666666"
                android:textSize="11sp"
                android:fontFamily="@font/unageo_regular"
                android:layout_marginTop="1dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginHorizontal="6dp"
        android:layout_marginVertical="2dp"
        android:background="#1AFFFFFF"/>

    <!-- Opción 2: Borrar memoria (rojo) -->
    <LinearLayout
        android:id="@+id/menuItemClearMemory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="@drawable/bg_aria_popup_item"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_aria_popup_icon_danger"
            android:layout_marginEnd="10dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_delete"
                app:tint="#E21616"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Borrar memoria"
                android:textColor="#E21616"
                android:textSize="13sp"
                android:fontFamily="@font/unageo_medium"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reiniciar conversación"
                android:textColor="#662222"
                android:textSize="11sp"
                android:fontFamily="@font/unageo_regular"
                android:layout_marginTop="1dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
