<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Header: transition summary -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/transitionIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_compare_arrows"
            android:layout_marginEnd="14dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/headerLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COPIAR TRANSICIÓN"
                android:textColor="#88FFFFFF"
                android:textSize="10sp"
                android:fontFamily="@font/unageo_medium"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/songATitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="@font/unageo_bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/songBTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/unageo_medium"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/compatScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:fontFamily="@font/unageo_bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/compatVerdict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:fontFamily="@font/unageo_medium"
                android:letterSpacing="0.05"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/no_selected_color_icon"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp" />

    <TextView
        android:id="@+id/selectLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿A qué PlayMix deseas copiar?"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:fontFamily="@font/unageo_regular"
        android:layout_margin="20dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/playmixList"
        android:layout_width="match_parent"
        android:layout_height="380dp"
        android:padding="15dp"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/noPlaymixTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:fontFamily="@font/unageo_regular"
        android:gravity="start|center_vertical"
        android:text="No tienes otras PlayMixes disponibles"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:visibility="gone" />

</LinearLayout>
