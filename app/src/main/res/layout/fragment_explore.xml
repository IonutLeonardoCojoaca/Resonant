<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primaryColorTheme"
    tools:context=".ui.fragments.ExploreFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/exploreScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="188dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/superiorToolbar"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:paddingHorizontal="14dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/userProfile"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_user"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/CircularUserImage" />

                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/unageo_bold"
                    android:text="Explorar"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/userProfile"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/searchButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="9dp"
                    android:src="@drawable/ic_search"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/exploreIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/exploreHeroTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/unageo_bold"
                    android:includeFontPadding="false"
                    android:text="Descubre sin ruido"
                    android:textColor="@color/white"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/exploreHeroSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/unageo_regular"
                    android:lineSpacingExtra="2dp"
                    android:text="Atajos, artistas, albumes y generos para abrir rapido."
                    android:textColor="#A7A7A7"
                    android:textSize="14sp" />

            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/quickActionsScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="6dp"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/quickActionsGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="15dp"
                    android:theme="@style/Theme.MaterialComponents.Light"
                    app:chipSpacingHorizontal="6dp"
                    app:selectionRequired="true"
                    app:singleSelection="true"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/btnArtistas"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:checkable="true"
                        android:text="Artistas"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        app:checkedIconVisible="false"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipCornerRadius="35dp"
                        app:chipStrokeColor="@android:color/transparent"
                        app:fontFamily="@font/unageo_medium"
                        app:rippleColor="@android:color/transparent"
                        app:useMaterialThemeColors="false" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/btnAlbumes"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:checkable="true"
                        android:text="Albumes"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        app:checkedIconVisible="false"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipCornerRadius="35dp"
                        app:chipStrokeColor="@android:color/transparent"
                        app:fontFamily="@font/unageo_medium"
                        app:rippleColor="@android:color/transparent"
                        app:useMaterialThemeColors="false" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/btnPopulares"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:checkable="true"
                        android:text="Top diario"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        app:checkedIconVisible="false"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipCornerRadius="35dp"
                        app:chipStrokeColor="@android:color/transparent"
                        app:fontFamily="@font/unageo_medium"
                        app:rippleColor="@android:color/transparent"
                        app:useMaterialThemeColors="false" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/btnTrending"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:checkable="true"
                        android:text="Tendencias"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        app:checkedIconVisible="false"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipCornerRadius="35dp"
                        app:chipStrokeColor="@android:color/transparent"
                        app:fontFamily="@font/unageo_medium"
                        app:rippleColor="@android:color/transparent"
                        app:useMaterialThemeColors="false" />

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/collabFinderSection"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/transparent"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_explore_collab_card"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/collabEyebrow"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_explore_badge"
                        android:fontFamily="@font/unageo_bold"
                        android:gravity="center"
                        android:letterSpacing="0.06"
                        android:paddingHorizontal="9dp"
                        android:text="COLLAB FINDER"
                        android:textColor="#D8D8D8"
                        android:textSize="9sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/collabVisualPanel"
                        android:layout_width="132dp"
                        android:layout_height="150dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <FrameLayout
                            android:id="@+id/collabPrimaryArtistFrame"
                            android:layout_width="78dp"
                            android:layout_height="78dp"
                            android:background="@drawable/bg_explore_collab_avatar_ring"
                            android:elevation="4dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/collabPrimaryArtistImage"
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:layout_gravity="center"
                                android:background="#242424"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_user"
                                app:shapeAppearanceOverlay="@style/CircularUserImage"
                                tools:src="@drawable/ic_user" />

                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/collabSecondaryArtistFrame"
                            android:layout_width="74dp"
                            android:layout_height="74dp"
                            android:background="@drawable/bg_explore_collab_avatar_ring"
                            android:elevation="5dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/collabPrimaryArtistFrame"
                            app:layout_constraintVertical_bias="0.55"
                            app:layout_constraintBottom_toBottomOf="@id/collabPrimaryArtistFrame">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/collabSecondaryArtistImage"
                                android:layout_width="66dp"
                                android:layout_height="66dp"
                                android:layout_gravity="center"
                                android:background="#242424"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_user"
                                app:shapeAppearanceOverlay="@style/CircularUserImage"
                                tools:src="@drawable/ic_user" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/collabPlus"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_explore_collab_plus"
                            android:elevation="6dp"
                            android:fontFamily="@font/unageo_bold"
                            android:gravity="center"
                            android:text="+"
                            android:textColor="@color/white"
                            android:textSize="17sp"
                            app:layout_constraintBottom_toBottomOf="@id/collabPrimaryArtistFrame"
                            app:layout_constraintEnd_toEndOf="@id/collabPrimaryArtistFrame"
                            app:layout_constraintStart_toStartOf="@id/collabSecondaryArtistFrame"
                            app:layout_constraintTop_toTopOf="@id/collabSecondaryArtistFrame" />

                        <TextView
                            android:id="@+id/collabPrimaryArtistName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:ellipsize="end"
                            android:fontFamily="@font/unageo_bold"
                            android:gravity="center"
                            android:maxLines="1"
                            android:text="Tu artista top"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/collabPrimaryArtistFrame" />

                        <TextView
                            android:id="@+id/collabSecondaryArtistName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:fontFamily="@font/unageo_medium"
                            android:gravity="center"
                            android:maxLines="1"
                            android:text="Segundo artista"
                            android:textColor="#B8B8B8"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/collabPrimaryArtistName" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/collabTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="16dp"
                        android:fontFamily="@font/unageo_bold"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="1dp"
                        android:maxLines="2"
                        android:text="Encuentra conexiones"
                        android:textColor="@color/white"
                        android:textSize="21sp"
                        app:layout_constraintEnd_toStartOf="@id/collabVisualPanel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/collabEyebrow" />

                    <TextView
                        android:id="@+id/collabSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="16dp"
                        android:fontFamily="@font/unageo_regular"
                        android:lineSpacingExtra="2dp"
                        android:maxLines="2"
                        android:text="Cruza tus artistas top y descubre colaboraciones que ya existen."
                        android:textColor="#B8B8B8"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@id/collabVisualPanel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/collabTitle" />

                    <TextView
                        android:id="@+id/collabPairMeta"
                        android:layout_width="0dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_explore_collab_metric"
                        android:ellipsize="end"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="center_vertical"
                        android:maxLines="1"
                        android:paddingHorizontal="10dp"
                        android:text="Basado en tus escuchas"
                        android:textColor="#D6D6D6"
                        android:textSize="11sp"
                        app:layout_constraintEnd_toStartOf="@id/collabVisualPanel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/collabSubtitle" />

                    <TextView
                        android:id="@+id/collabFinderButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_explore_collab_button"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/unageo_bold"
                        android:gravity="center"
                        android:minWidth="164dp"
                        android:paddingHorizontal="16dp"
                        android:text="Abrir buscador"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/collabPairMeta" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/playlistsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:orientation="vertical">

                <include
                    android:id="@+id/playlistsHeader"
                    layout="@layout/view_explore_section_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/playlistsSectionSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-2dp"
                    android:fontFamily="@font/unageo_regular"
                    android:paddingHorizontal="18dp"
                    android:text="Seleccionadas para descubrir musica nueva sin salir de Explorar."
                    android:textColor="#8E8E8E"
                    android:textSize="13sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="372dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewPlaylists"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingHorizontal="13dp"
                        android:scrollbars="none"
                        tools:itemCount="7"
                        tools:listitem="@layout/item_explore_playlist" />

                    <TextView
                        android:id="@+id/playlistsPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:fontFamily="@font/unageo_regular"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="18dp"
                        android:text="Cargando playlists..."
                        android:textColor="#707070"
                        android:textSize="14sp" />

                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/artistsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <include
                    android:id="@+id/artistsHeader"
                    layout="@layout/view_explore_section_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="194dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewArtists"
                        android:layout_width="match_parent"
                        android:layout_height="194dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingStart="13dp"
                        android:paddingEnd="18dp"
                        android:scrollbars="none"
                        tools:itemCount="6"
                        tools:listitem="@layout/item_explore_artist" />

                    <TextView
                        android:id="@+id/artistsPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="184dp"
                        android:fontFamily="@font/unageo_regular"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="18dp"
                        android:text="Cargando artistas..."
                        android:textColor="#707070"
                        android:textSize="14sp" />

                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/albumsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <include
                    android:id="@+id/albumsHeader"
                    layout="@layout/view_explore_section_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="142dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewAlbums"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingHorizontal="8dp"
                        android:scrollbars="none"
                        tools:itemCount="6"
                        tools:listitem="@layout/item_explore_album" />

                    <TextView
                        android:id="@+id/albumsPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="132dp"
                        android:fontFamily="@font/unageo_regular"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="18dp"
                        android:text="Cargando albumes..."
                        android:textColor="#707070"
                        android:textSize="14sp" />

                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/genresSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <include
                    android:id="@+id/genresHeader"
                    layout="@layout/view_explore_section_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="142dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewGenres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingHorizontal="8dp"
                        android:scrollbars="none"
                        tools:itemCount="8"
                        tools:listitem="@layout/item_genre" />

                    <TextView
                        android:id="@+id/genresPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="132dp"
                        android:fontFamily="@font/unageo_regular"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="18dp"
                        android:text="Cargando generos..."
                        android:textColor="#707070"
                        android:textSize="14sp" />

                </FrameLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        layout="@layout/view_search_header"
        android:layout_width="match_parent"
        android:layout_height="56dp" />

</FrameLayout>
