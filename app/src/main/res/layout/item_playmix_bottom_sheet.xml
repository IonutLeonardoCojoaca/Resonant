<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp"
    android:background="@color/pointersTheme">

    <ImageView
        android:id="@+id/playmixIcon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_playmix"
        android:scaleType="fitCenter"
        app:tint="#99FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/playmixIcon"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/playmixName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:fontFamily="@font/unageo_bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/playmixTrackCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/no_selected_color_icon"
            android:fontFamily="@font/unageo_regular"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
