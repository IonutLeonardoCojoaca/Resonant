<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1A1A1A"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_compat_chip" />

    <!-- Loading state -->
    <LinearLayout
        android:id="@+id/previewLoading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminate="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/unageo_medium"
            android:text="Calculando preview..."
            android:textColor="#99FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Content state -->
    <LinearLayout
        android:id="@+id/previewContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:visibility="gone">

        <!-- Preset icon + name -->
        <TextView
            android:id="@+id/previewPresetName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/unageo_bold"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <!-- Description -->
        <TextView
            android:id="@+id/previewPresetDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/unageo_regular"
            android:gravity="center"
            android:textColor="#99FFFFFF"
            android:textSize="13sp" />

        <!-- Mini waveform preview -->
        <com.example.resonant.ui.views.WaveformView
            android:id="@+id/previewWaveform"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="16dp" />

        <!-- Calculated values -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_crossfade_panel"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/unageo_medium"
                    android:text="Crossfade"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/previewCrossfade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/unageo_bold"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/unageo_medium"
                    android:text="Curva"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/previewCurve"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/unageo_bold"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/unageo_medium"
                    android:text="Salida"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/previewExitPoint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/unageo_bold"
                    android:textColor="#E21616"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/unageo_medium"
                    android:text="Entrada"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/previewEntryPoint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/unageo_bold"
                    android:textColor="#BB86FC"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/previewGapRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/unageo_medium"
                    android:text="Gap"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/previewGap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/unageo_bold"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Warnings container -->
        <LinearLayout
            android:id="@+id/previewWarningsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/previewCancelButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_preview_button"
                android:fontFamily="@font/unageo_bold"
                android:gravity="center"
                android:text="Cancelar"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/previewApplyButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_save_button"
                android:fontFamily="@font/unageo_bold"
                android:gravity="center"
                android:text="Aplicar Preset ✓"
                android:textColor="@color/white"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
