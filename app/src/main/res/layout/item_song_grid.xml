<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/songRoot"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:layout_margin="4dp"
    app:cardCornerRadius="6dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:rippleColor="@color/ripple_white"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/itemContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#2A2A2A">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/songImage"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:scaleType="centerCrop"/>

        <ImageView
            android:id="@+id/playIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_play"
            app:tint="@color/white"
            android:background="@drawable/bg_play_background"
            android:backgroundTint="#80000000"
            android:padding="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/songImage"
            app:layout_constraintBottom_toBottomOf="@id/songImage"
            app:layout_constraintStart_toStartOf="@id/songImage"
            app:layout_constraintEnd_toEndOf="@id/songImage"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/songImage"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/songTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Song title"
                android:textAlignment="viewStart"
                android:textColor="@color/white"
                android:fontFamily="@font/unageo_bold"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/songArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Artist"
                android:textAlignment="viewStart"
                android:textColor="#B0B0B0"
                android:fontFamily="@font/unageo_medium"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="visible"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
