<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="10dp"
    android:paddingVertical="2dp">

    <View
        android:layout_width="2dp"
        android:layout_height="10dp"
        android:layout_gravity="center_horizontal"
        android:background="#22FFFFFF" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_playmix_transition_item"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:padding="12dp">

        <ImageView
            android:id="@+id/transitionIcon"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_compat_chip"
            android:padding="7dp"
            android:src="@drawable/ic_compare_arrows"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/transitionVerdict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_compat_chip"
            android:fontFamily="@font/unageo_bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="BUENA"
            android:textColor="@color/white"
            android:textSize="10sp"
            app:layout_constraintStart_toEndOf="@id/transitionIcon"
            app:layout_constraintTop_toTopOf="@id/transitionIcon"
            android:layout_marginStart="10dp" />

        <TextView
            android:id="@+id/transitionModeChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_measure_dropdown"
            android:fontFamily="@font/unageo_medium"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Crossfade"
            android:textColor="#D9FFFFFF"
            android:textSize="10sp"
            app:layout_constraintBaseline_toBaselineOf="@id/transitionVerdict"
            app:layout_constraintStart_toEndOf="@id/transitionVerdict" />

        <TextView
            android:id="@+id/transitionDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:fontFamily="@font/unageo_bold"
            android:maxLines="1"
            android:text="4.8s · preset aplicado"
            android:textColor="@color/white"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/transitionActions"
            app:layout_constraintStart_toStartOf="@id/transitionVerdict"
            app:layout_constraintTop_toBottomOf="@id/transitionVerdict" />

        <LinearLayout
            android:id="@+id/transitionMetaRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toStartOf="@id/transitionActions"
            app:layout_constraintStart_toStartOf="@id/transitionVerdict"
            app:layout_constraintTop_toBottomOf="@id/transitionDetails">

            <TextView
                android:id="@+id/transitionKeyChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_compat_chip"
                android:fontFamily="@font/unageo_medium"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Relative minor"
                android:textColor="#D9FFFFFF"
                android:textSize="10sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/transitionPresetChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_compat_chip"
                android:fontFamily="@font/unageo_medium"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Preset"
                android:textColor="#D9FFFFFF"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/transitionActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@id/transitionMetaRow"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/transitionDetails">

            <ImageView
                android:id="@+id/waveformPreviewButton"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_preview_overlay_button"
                android:padding="9dp"
                android:src="@drawable/ic_play"
                app:tint="@color/white" />

            <ImageView
                android:id="@+id/copyTransitionButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_playmix"
                app:tint="#CCFFFFFF" />

            <ImageView
                android:id="@+id/editTransitionButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_edit"
                app:tint="#CCFFFFFF" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:layout_width="2dp"
        android:layout_height="10dp"
        android:layout_gravity="center_horizontal"
        android:background="#22FFFFFF" />

</LinearLayout>
