<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/searchHeader"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:paddingHorizontal="12dp"
    android:background="@drawable/bg_search_header"
    android:elevation="8dp"
    android:translationY="-56dp"
    android:visibility="invisible">

    <!-- Input de búsqueda -->
    <androidx.cardview.widget.CardView
        android:id="@+id/searchInputContainer"
        android:layout_width="0dp"
        android:layout_height="40dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/searchHeaderAvatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/searchInputClickable"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="8dp"
                app:tint="#666666"/>

            <TextView
                android:id="@+id/searchHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Buscar en Resonant"
                android:textColor="#666666"
                android:textSize="14sp"
                android:fontFamily="@font/unageo_regular"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Avatar usuario -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/searchHeaderAvatar"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:src="@drawable/ic_user"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/CircularUserImage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
