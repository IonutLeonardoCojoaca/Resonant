<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="70dp"
    android:layout_marginVertical="2dp"
    android:paddingHorizontal="8dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <View
        android:id="@+id/view3"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="0dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:background="@drawable/bg_album_item"
        android:translationY="-3dp"
        android:translationX="7dp"/>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/albumImage"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="0dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:translationY="2dp"
        app:shapeAppearanceOverlay="@style/RoundedCornersImage">

    </com.google.android.material.imageview.ShapeableImageView>

    <RelativeLayout
        android:id="@+id/albumDataContainer"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="8dp"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/view3"
        android:layout_toStartOf="@id/settingsButton">

        <TextView
            android:id="@+id/albumTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/unageo_medium"
            android:text=""
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_alignParentTop="true"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/dataType"
            android:layout_width="wrap_content"
            android:layout_height="18dp"
            android:text="Álbum"
            android:textSize="12sp"
            android:textColor="#BDBDBD"
            android:fontFamily="@font/unageo_medium"
            android:layout_alignParentBottom="true"/>

        <TextView
            android:id="@+id/separator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="3dp"
            android:text="●"
            android:layout_alignParentBottom="true"
            android:textColor="#BDBDBD"
            android:layout_toRightOf="@id/dataType"/>

        <TextView
            android:id="@+id/albumArtistName"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:text=""
            android:fontFamily="@font/unageo_medium"
            android:textColor="#BDBDBD"
            android:textSize="12sp"
            android:layout_alignParentBottom="true"
            android:layout_toRightOf="@id/separator"
            android:maxLines="1"
            android:ellipsize="end"/>

    </RelativeLayout>

    <ImageButton
        android:id="@+id/settingsButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_item_settings"
        app:tint="#BDBDBD"
        android:contentDescription="Opciones" />

</RelativeLayout>