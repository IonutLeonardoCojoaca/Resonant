<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="152dp"
    android:layout_height="184dp"
    android:layout_margin="5dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/transparent"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeColor="#2A2A2A"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_explore_artist_motion_card"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/artistTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="18dp"
            android:background="@drawable/bg_explore_badge"
            android:fontFamily="@font/unageo_bold"
            android:gravity="center"
            android:letterSpacing="0.06"
            android:paddingHorizontal="8dp"
            android:text="ARTISTA"
            android:textColor="#D8D8D8"
            android:textSize="9sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/artistAvatarRing"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_marginTop="7dp"
            android:background="@drawable/bg_explore_artist_avatar_ring"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/artistTypeLabel">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/artistImage"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_gravity="center"
                android:background="#242424"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_user"
                app:shapeAppearanceOverlay="@style/CircularUserImage"
                app:strokeColor="#40FFFFFF"
                app:strokeWidth="1dp"
                tools:src="@drawable/ic_user" />

        </FrameLayout>

        <TextView
            android:id="@+id/artistName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:ellipsize="end"
            android:fontFamily="@font/unageo_bold"
            android:gravity="center"
            android:lineSpacingExtra="1dp"
            android:maxLines="2"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/artistAvatarRing"
            tools:text="The Weeknd" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
