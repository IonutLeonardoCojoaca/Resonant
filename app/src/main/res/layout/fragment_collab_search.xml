<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:fontFamily="@font/unageo_extra_bold"
        android:letterSpacing="0.14"
        android:text="COLLAB FINDER"
        android:textColor="#F51B1F"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="54dp"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/unageo_regular"
        android:gravity="center"
        android:lineSpacingExtra="1dp"
        android:text="Con esta funci&#243;n podr&#225;s buscar las colaboraciones de tus artistas favoritos con otros artistas y descubrir nuevas canciones"
        android:textColor="#D8D8D8"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLogo" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/bottomActionsTopBarrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="18dp">

            <FrameLayout
                android:id="@+id/orbitFrame"
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:layout_marginTop="22dp">

                <com.example.resonant.feature.collabfinder.ui.views.BubbleOrbitView
                    android:id="@+id/bubbleOrbitView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/collabEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="42dp">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/collabLoader"
                        android:layout_width="172dp"
                        android:layout_height="172dp"
                        android:visibility="gone"
                        app:lottie_autoPlay="false"
                        app:lottie_enableMergePathsForKitKatAndAbove="true"
                        app:lottie_fileName="loader.json"
                        app:lottie_loop="true"
                        app:lottie_repeatCount="-1" />

                    <TextView
                        android:id="@+id/tvOrbitStateTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/unageo_bold"
                        android:gravity="center"
                        android:text="Busca un artista"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/tvOrbitStateSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/unageo_regular"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:text="Las colaboraciones aparecer&#225;n cuando encontremos conexiones."
                        android:textColor="#8F8F8F"
                        android:textSize="12sp" />
                </LinearLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/tvArtistName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="28dp"
                android:layout_marginTop="20dp"
                android:ellipsize="end"
                android:fontFamily="@font/unageo_bold"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="#FFFFFF"
                android:textSize="21sp"
                android:visibility="gone"
                tools:text="The Weeknd"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvCollabSubtext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="34dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/unageo_regular"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:textColor="#BCBCBC"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="Se han encontrado 24 colaboraciones con artistas"
                tools:visibility="visible" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/bottomActionsTopBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierAllowsGoneWidgets="false"
        app:barrierDirection="top"
        app:constraint_referenced_ids="searchFieldCard,btnSearchAnother" />

    <androidx.cardview.widget.CardView
        android:id="@+id/searchFieldCard"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="18dp"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="26dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/btnBuscar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#808080" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="@font/unageo_regular"
                android:hint="The Weeknd"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/btnClearSearch"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:visibility="gone"
                app:tint="#808080" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSearchAnother"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="88dp"
        android:layout_marginBottom="12dp"
        android:fontFamily="@font/unageo_bold"
        android:text="Buscar otro"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:visibility="gone"
        app:backgroundTint="#2A2A2A"
        app:cornerRadius="22dp"
        app:layout_constraintBottom_toTopOf="@id/btnBuscar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBuscar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="88dp"
        android:layout_marginBottom="82dp"
        android:fontFamily="@font/unageo_bold"
        android:text="Buscar"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        app:backgroundTint="#F01A1D"
        app:cornerRadius="22dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:indeterminateTint="#FF0000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/contentScroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/contentScroll" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardSuggestions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="4dp"
        android:elevation="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchFieldCard">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
