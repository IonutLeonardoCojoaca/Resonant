<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:minHeight="76dp"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="14dp"
    android:paddingVertical="11dp">

    <!-- Número de posición -->
    <TextView
        android:id="@+id/rankText"
        android:layout_width="40dp"
        android:layout_height="28dp"
        android:background="@drawable/bg_top_chart_rank_badge"
        android:text="#2"
        android:textSize="13sp"
        android:textColor="@color/white"
        android:fontFamily="@font/unageo_bold"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/trendRow" />

    <!-- Trend badge -->
    <LinearLayout
        android:id="@+id/trendRow"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rankText"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/ivTrendIcon"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="2dp"
            android:src="@drawable/ic_trend_neutral" />

        <TextView
            android:id="@+id/tvPositionChange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="9sp"
            android:textColor="@color/white"
            android:fontFamily="@font/unageo_medium" />
    </LinearLayout>

    <!-- Portada del álbum con esquinas redondeadas -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/albumImage"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_playlist_stack"
        app:shapeAppearanceOverlay="@style/RoundedCornersImage"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/rankText"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Nombre del álbum, artista y año -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        app:layout_constraintStart_toEndOf="@id/albumImage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/albumName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del Álbum"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:fontFamily="@font/unageo_bold"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/albumArtist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del Artista"
            android:textSize="12sp"
            android:textColor="#AAFFFFFF"
            android:fontFamily="@font/unageo_medium"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/albumInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Año: 2024"
            android:textSize="11sp"
            android:textColor="#66FFFFFF"
            android:fontFamily="@font/unageo_regular"
            android:layout_marginTop="1dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
