<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootConstraint"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primaryColorTheme"
    tools:context=".ui.fragments.DetailedArtistFragment">

    <View
        android:id="@+id/view4"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_gradient_bottom_song_list"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="1.25"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="200dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/artistImage"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircularUserImage" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_toRightOf="@id/artistImage"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/artistName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/unageo_bold"
                        android:maxLines="2"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        tools:text="Nombre del Artista" />

                    <TextView
                        android:id="@+id/itemType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_border_item_type"
                        android:fontFamily="@font/unageo_regular"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:text="Artista"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                </LinearLayout>

            </RelativeLayout>

            <TextView
                android:id="@+id/informationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/unageo_bold"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="Información detallada"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/artistDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:ellipsize="end"
                android:fontFamily="@font/unageo_medium"
                android:maxLines="5"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="Biografía del artista..."
                tools:visibility="visible" />

            <TextView
                android:id="@+id/genresHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/unageo_bold"
                android:text="Géneros asociados al artista"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/genresRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:visibility="gone"
                tools:listitem="@layout/item_genre_mini"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/albumsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/unageo_bold"
                android:text="Álbumes"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/albumCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="18dp"
                android:fontFamily="@font/unageo_medium"
                android:textColor="#BDBDBD"
                android:textSize="14sp"
                tools:text="5 álbumes" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/albumsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp"
                android:paddingTop="10dp" />

            <!-- STATS SECTION -->
            <TextView
                android:id="@+id/statsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/unageo_bold"
                android:text="Estadísticas"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/statsCardsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="12dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/cardTotalSongs"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_border_item_type"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/statTotalSongs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/unageo_bold"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:text="—"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/unageo_regular"
                        android:textColor="#BDBDBD"
                        android:textSize="11sp"
                        android:text="Canciones"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardTotalAlbums"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_border_item_type"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/statTotalAlbums"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/unageo_bold"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:text="—"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/unageo_regular"
                        android:textColor="#BDBDBD"
                        android:textSize="11sp"
                        android:text="Álbumes"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardTotalStreams"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_border_item_type"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/statTotalStreams"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/unageo_bold"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:text="—"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/unageo_regular"
                        android:textColor="#BDBDBD"
                        android:textSize="11sp"
                        android:text="Escuchas"/>
                </LinearLayout>

            </LinearLayout>

            <!-- COLLABORATORS SECTION -->
            <TextView
                android:id="@+id/collaboratorsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/unageo_bold"
                android:text="Colaboradores"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/collaboratorsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:paddingHorizontal="10dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>