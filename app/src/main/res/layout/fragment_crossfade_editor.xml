<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primaryColorTheme"
    tools:context=".ui.fragments.CrossfadeEditorFragment">

    <!-- Top bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:layout_alignParentTop="true">

        <ImageButton
            android:id="@+id/arrowGoBackButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleX="0.8"
            android:scaleY="0.8"
            android:background="@color/transparent"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/editorTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:ellipsize="end"
            android:fontFamily="@font/unageo_medium"
            android:gravity="center"
            android:maxLines="1"
            android:text="Editor de Crossfade"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/arrowGoBackButton"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="120dp">

            <!-- Song A → Song B header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/songATitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/unageo_bold"
                        android:maxLines="1"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/songAArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/unageo_regular"
                        android:maxLines="1"
                        android:textColor="#99FFFFFF"
                        android:textSize="11sp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="8dp"
                    android:src="@drawable/ic_compare_arrows"
                    app:tint="#66FFFFFF" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/songBTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/unageo_bold"
                        android:gravity="end"
                        android:maxLines="1"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/songBArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/unageo_regular"
                        android:gravity="end"
                        android:maxLines="1"
                        android:textColor="#99FFFFFF"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══ Compatibility Panel (colapsable) ═══ -->
            <LinearLayout
                android:id="@+id/compatibilityPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_crossfade_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header with collapse toggle -->
                <LinearLayout
                    android:id="@+id/compatHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/unageo_bold"
                        android:text="Compatibilidad"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/compatToggle"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_keyboard_arrow_up"
                        app:tint="#99FFFFFF" />

                </LinearLayout>

                <!-- Collapsible content -->
                <LinearLayout
                    android:id="@+id/compatContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <!-- Chips row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipBpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_compat_chip"
                            android:fontFamily="@font/unageo_medium"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipKey"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_compat_chip"
                            android:fontFamily="@font/unageo_medium"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/chipVolume"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_compat_chip"
                            android:fontFamily="@font/unageo_medium"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Score -->
                    <TextView
                        android:id="@+id/overallScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/unageo_bold"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="32sp" />

                    <TextView
                        android:id="@+id/verdictText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="center"
                        android:textSize="14sp" />

                    <!-- Suggestions -->
                    <LinearLayout
                        android:id="@+id/suggestionsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══ BPM Sync Panel ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_crossfade_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/unageo_bold"
                    android:text="BPM Sync"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <!-- BPM Display Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Song A BPM -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_medium"
                            android:text="Song A"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/bpmAValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_bold"
                            android:textColor="#E21616"
                            android:textSize="20sp"
                            android:text="-- BPM" />

                        <TextView
                            android:id="@+id/syncToAButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_preset_chip"
                            android:fontFamily="@font/unageo_medium"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="Usar este"
                            android:textColor="@color/white"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- Arrow + Target BPM -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_medium"
                            android:text="Target"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/targetBpmValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_bold"
                            android:textColor="#4CAF50"
                            android:textSize="22sp"
                            android:text="-- BPM" />

                    </LinearLayout>

                    <!-- Song B BPM -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_medium"
                            android:text="Song B"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/bpmBValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_bold"
                            android:textColor="#BB86FC"
                            android:textSize="20sp"
                            android:text="-- BPM" />

                        <TextView
                            android:id="@+id/syncToBButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_preset_chip"
                            android:fontFamily="@font/unageo_medium"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="Usar este"
                            android:textColor="@color/white"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- BPM Slider -->
                <com.google.android.material.slider.Slider
                    android:id="@+id/bpmSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:valueFrom="60"
                    android:valueTo="200"
                    android:stepSize="0"
                    app:trackColorActive="#4CAF50"
                    app:trackColorInactive="#2A2A2A"
                    app:thumbColor="#4CAF50" />

                <!-- Pitch indicators -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/pitchALabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/unageo_medium"
                        android:textColor="#99FFFFFF"
                        android:textSize="11sp"
                        android:text="A: ±0.0%" />

                    <TextView
                        android:id="@+id/pitchBLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="end"
                        android:textColor="#99FFFFFF"
                        android:textSize="11sp"
                        android:text="B: ±0.0%" />

                </LinearLayout>

                <!-- Auto Match button + score -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/autoMatchButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_preview_button"
                        android:fontFamily="@font/unageo_bold"
                        android:gravity="center"
                        android:text="Auto Beat Match"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/beatAlignScoreLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_bold"
                            android:textColor="#4CAF50"
                            android:textSize="16sp"
                            android:text="0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_medium"
                            android:textColor="#66FFFFFF"
                            android:textSize="10sp"
                            android:text="beats alineados" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ═══ Waveform Visualizer ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_crossfade_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_bold"
                            android:text="Visualizador"
                            android:textColor="@color/white"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/unageo_regular"
                            android:text="Arrastra cada pista para mover el punto · suelta para ajustar al beat"
                            android:textColor="#88FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Waveform -->
                <com.example.resonant.ui.views.WaveformView
                    android:id="@+id/waveformView"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="12dp" />

                <!-- Current timecodes row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_medium"
                            android:text="Exit point"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/exitPointLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_bold"
                            android:textColor="#E21616"
                            android:textSize="14sp"
                            android:text="0:00.0" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_medium"
                            android:text="Crossfade"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/crossfadeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_bold"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:text="8s" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_medium"
                            android:text="Entry point"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/entryPointLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/unageo_bold"
                            android:textColor="#BB86FC"
                            android:textSize="14sp"
                            android:text="0:00.0" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ═══ Sugerencias Óptimas ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_crossfade_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/unageo_bold"
                    android:text="Sugerencias Óptimas"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/unageo_regular"
                    android:text="Duraciones alineadas al BPM de la mezcla"
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp" />

                <LinearLayout
                    android:id="@+id/beatPresetsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/preset4beats"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_preset_chip"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="center"
                        android:text="4 beats"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/preset8beats"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_preset_chip"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="center"
                        android:text="8 beats"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/preset16beats"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/bg_preset_chip"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="center"
                        android:text="16 beats"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/preset32beats"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_preset_chip"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="center"
                        android:text="32 beats"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══ Fade Curve Selector (kept, no sliders) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_crossfade_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Fade Curve Selector -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/unageo_medium"
                    android:text="Curva de Fade"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/curveLinear"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_curve_selector"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="center"
                        android:text="Linear"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/curveExp"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_curve_selector"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="center"
                        android:text="Exp"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/curveLog"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_curve_selector"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="center"
                        android:text="Log"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/curveCustom"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_curve_selector"
                        android:fontFamily="@font/unageo_medium"
                        android:gravity="center"
                        android:text="Custom"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══ Equalizer (5 bands) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_eq_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/unageo_bold"
                        android:text="Ecualizador"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/resetEqButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/unageo_medium"
                        android:text="Reset"
                        android:textColor="#E21616"
                        android:textSize="13sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp" />

                </LinearLayout>

                <!-- EQ Sliders container -->
                <LinearLayout
                    android:id="@+id/eqSlidersContainer"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="horizontal" />

            </LinearLayout>

            <!-- ═══ Action Buttons ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/previewButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_preview_button"
                    android:fontFamily="@font/unageo_bold"
                    android:gravity="center"
                    android:text="Preview"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/saveButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_save_button"
                    android:fontFamily="@font/unageo_bold"
                    android:gravity="center"
                    android:text="Guardar"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Loader -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieLoader"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_centerInParent="true"
        app:lottie_fileName="loader.json"
        app:lottie_autoPlay="false"
        app:lottie_loop="true"
        app:lottie_repeatCount="-1"
        app:lottie_enableMergePathsForKitKatAndAbove="true" />

</RelativeLayout>
