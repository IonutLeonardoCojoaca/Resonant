<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:minHeight="76dp"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="14dp"
    android:paddingVertical="11dp">

    <!-- Número de posición -->
    <TextView
        android:id="@+id/rankText"
        android:layout_width="40dp"
        android:layout_height="28dp"
        android:background="@drawable/bg_top_chart_rank_badge"
        android:text="#2"
        android:textSize="13sp"
        android:textColor="@color/white"
        android:fontFamily="@font/unageo_bold"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Foto circular del artista -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/artistImage"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_user"
        app:shapeAppearanceOverlay="@style/CircularUserImage"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/rankText"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Nombre y subtítulo -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        app:layout_constraintStart_toEndOf="@id/artistImage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/artistName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del Artista"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:fontFamily="@font/unageo_bold"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/artistStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Artista Popular"
            android:textSize="12sp"
            android:textColor="#AAFFFFFF"
            android:fontFamily="@font/unageo_medium"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
