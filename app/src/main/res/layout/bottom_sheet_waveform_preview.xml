<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_visibility"
            app:tint="#CCFFFFFF"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Vista previa del crossfade"
            android:textColor="@color/white"
            android:fontFamily="@font/unageo_bold"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/closeButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            app:tint="#88FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- Song labels row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/songALabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#CCE21616"
            android:fontFamily="@font/unageo_medium"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/songBLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="end"
            android:textColor="#CCFFFFFF"
            android:fontFamily="@font/unageo_medium"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Waveform -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginHorizontal="8dp">

        <com.example.resonant.ui.views.WaveformView
            android:id="@+id/previewWaveform"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/waveformLoading"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Controls row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp">

        <TextView
            android:id="@+id/playPreviewButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:text="▶  Vista previa"
            android:textColor="@color/white"
            android:fontFamily="@font/unageo_bold"
            android:textSize="13sp"
            android:background="@drawable/bg_transition_indicator" />

    </LinearLayout>

    <!-- Error message -->
    <TextView
        android:id="@+id/errorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:textColor="#EF5350"
        android:fontFamily="@font/unageo_medium"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
