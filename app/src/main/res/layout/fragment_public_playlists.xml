<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primaryColorTheme">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="236dp"
            app:contentScrim="@color/primaryColorTheme"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:statusBarScrim="@color/primaryColorTheme"
            app:toolbarId="@+id/toolbar">

            <View
                android:id="@+id/parallaxGradient"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_public_playlists_header"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.6" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_public_playlists_header_glow"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.35" />

            <View
                android:layout_width="match_parent"
                android:layout_height="124dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom_overlay"
                app:layout_collapseMode="pin" />

            <LinearLayout
                android:id="@+id/headerTextContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingHorizontal="22dp"
                android:paddingBottom="24dp"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.35">

                <TextView
                    android:id="@+id/tvHeaderEyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_explore_badge"
                    android:fontFamily="@font/unageo_bold"
                    android:gravity="center"
                    android:letterSpacing="0.06"
                    android:paddingHorizontal="9dp"
                    android:text="COMUNIDAD"
                    android:textColor="#D8D8D8"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/unageo_bold"
                    android:includeFontPadding="false"
                    android:text="Playlists de la comunidad"
                    android:textColor="@color/white"
                    android:textSize="29sp" />

                <TextView
                    android:id="@+id/tvHeaderSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:fontFamily="@font/unageo_medium"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="2"
                    android:text="Colecciones reales de la comunidad, listas para descubrir musica nueva."
                    android:textColor="#C8FFFFFF"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/headerStatsRow"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_public_playlists_count_pill"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="11dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/unageo_bold"
                        android:text="Playlists publicas"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="13dp"
                        android:layout_marginHorizontal="9dp"
                        android:background="#30FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/unageo_medium"
                        android:text="Usuarios y Resonant"
                        android:textColor="#AFAFAF"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:contentInsetStartWithNavigation="0dp"
                app:layout_collapseMode="pin"
                app:navigationContentDescription="Atras"
                app:navigationIcon="@drawable/ic_arrow_back" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPublicPlaylists"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingHorizontal="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="112dp" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/secondaryColorTheme"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_playlist_stack"
            app:tint="#44FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/unageo_bold"
            android:text="No hay playlists publicas"
            android:textColor="#AAFFFFFF"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/unageo_medium"
            android:text="Se el primero en compartir la tuya"
            android:textColor="#66FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
