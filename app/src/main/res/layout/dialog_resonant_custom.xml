<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_advise_fragment">

    <!-- Cuerpo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <!-- Sección (opcional — oculto por defecto) -->
        <TextView
            android:id="@+id/dialogSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/unageo_bold"
            android:text="SECCIÓN"
            android:textColor="@color/secondaryColorTheme"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <!-- Título -->
        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/unageo_bold"
            android:text="Título"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:lineSpacingMultiplier="1.15"
            android:layout_marginBottom="10dp"/>

        <!-- Mensaje -->
        <TextView
            android:id="@+id/dialogMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/unageo_regular"
            android:text="Mensaje del diálogo"
            android:textColor="#70FFFFFF"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>

    <!-- Separador -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#18FFFFFF"/>

    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/negativeButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:fontFamily="@font/unageo_medium"
            android:gravity="center"
            android:text="Cancelar"
            android:textColor="#40FFFFFF"
            android:textSize="15sp"
            android:background="?attr/selectableItemBackground"
            android:visibility="gone"/>

        <View
            android:id="@+id/buttonDivider"
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="#18FFFFFF"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/positiveButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:fontFamily="@font/unageo_bold"
            android:gravity="center"
            android:text="Aceptar"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:background="?attr/selectableItemBackground"/>

    </LinearLayout>

</LinearLayout>