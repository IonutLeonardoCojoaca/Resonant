<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SpoMusicApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.SpoMusicApp" parent="Base.Theme.SpoMusicApp" />

    <!-- Tema para el Splash con fondo sólido, sin ActionBar -->
    <style name="Theme.Resonant.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@null</item>
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.Resonant.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">#1A1A1A</item>
        <item name="android:textColor">@color/white</item>
        <item name="colorAccent">#E21616</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#99FFFFFF</item>
    </style>
</resources>